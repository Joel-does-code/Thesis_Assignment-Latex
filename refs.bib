@article{Rambo,
author = {Pandit, Ram and Polyakov, Maksym and Sadler, Rohan},
title = {Valuing public and private urban tree canopy cover},
journal = {Australian Journal of Agricultural and Resource Economics},
volume = {58},
number = {3},
pages = {453-470},
keywords = {tree canopy cover, spatial hedonic model, spatiotemporal lag, property price, private space},
doi = {https://doi.org/10.1111/1467-8489.12037},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/1467-8489.12037},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/1467-8489.12037},
abstract = {In this paper, we estimate the effect of tree canopy cover on sales price of urban residential properties in Perth, Western Australia. Using a data set of 5606 single family homes sold in 2009 and a spatial hedonic model with three spatial effects – spatial-temporal lag on dependent variable, spatial error, and spatially lagged independent variables - we estimated the location-specific effect of tree canopy cover. Tree canopy cover increases the property value when located on adjacent public space, but decreases the value when it is on own property and on the adjacent property within 20 m of property boundary. The results are suggestive that council urban tree planting programs provide significant private benefits to homeowners.},
year = {2014}
}

